generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String        @id @default(cuid())
  googleId    String        @unique
  email       String        @unique
  name        String
  createdAt   DateTime      @default(now())
  sentences   Sentence[]
  weakWords   WeakWord[]
  sessions    Session[]
  bigramStats BigramStat[]
}

model Sentence {
  id           String           @id @default(cuid())
  userId       String
  text         String           @db.Text
  note         String?          @db.Text
  createdAt    DateTime         @default(now())
  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionLinks SessionSentence[]

  @@unique([userId, text(length: 500)])
}

model WeakWord {
  id               String   @id @default(cuid())
  userId           String
  word             String
  missRate         Float
  activeDurationMs Int      @default(0)
  msPerChar        Float    @default(0)
  stallCount       Int      @default(0)
  stallDurationMs  Int      @default(0)
  weaknessScore    Float    @default(0)
  primaryReason    String?
  isSolved         Boolean  @default(false)
  note             String?  @db.Text
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId, weaknessScore])
}

model Session {
  id               String            @id @default(cuid())
  userId           String
  mode             String            @default("sentence") // "sentence" | "weak_word" | "random" | "word_drill"
  totalKeys        Int
  missKeys         Int
  durationMs       Int
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionWords     SessionWord[]
  sessionSentences SessionSentence[]
}

model SessionWord {
  id               String  @id @default(cuid())
  sessionId        String
  word             String
  misses           Int
  activeDurationMs Int     @default(0)
  stallCount       Int     @default(0)
  stallDurationMs  Int     @default(0)
  session          Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SessionSentence {
  id         String   @id @default(cuid())
  sessionId  String
  sentenceId String
  position   Int
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sentence   Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)

  @@unique([sessionId, position])
  @@index([sentenceId])
}

model BigramStat {
  id       String @id @default(cuid())
  userId   String
  bigram   String // e.g. "wa", "qw"
  attempts Int    @default(0)
  misses   Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bigram])
}
