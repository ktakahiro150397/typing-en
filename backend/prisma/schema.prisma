generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id          String        @id @default(cuid())
  googleId    String        @unique
  email       String        @unique
  name        String
  createdAt   DateTime      @default(now())
  createdSentences Sentence[] @relation("SentenceCreator")
  weakWords   WeakWord[]
  sessions    Session[]
  bigramStats BigramStat[]
  settings    UserSettings?
}

model Sentence {
  id              String           @id @default(cuid())
  createdByUserId String?
  text            String           @db.Text
  translation     String?          @db.Text
  note            String?          @db.Text
  createdAt       DateTime         @default(now())
  createdBy       User?            @relation("SentenceCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  categories      SentenceCategory[]
  sessionLinks    SessionSentence[]

  @@unique([text(length: 500)])
  @@index([createdByUserId])
}

model SentenceCategory {
  id         String   @id @default(cuid())
  sentenceId String
  category   String   @db.VarChar(191)
  sentence   Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)

  @@unique([sentenceId, category])
  @@index([category])
}

model WeakWord {
  id               String   @id @default(cuid())
  userId           String
  word             String
  missRate         Float
  activeDurationMs Int      @default(0)
  msPerChar        Float    @default(0)
  stallCount       Int      @default(0)
  stallDurationMs  Int      @default(0)
  weaknessScore    Float    @default(0)
  primaryReason    String?
  isSolved         Boolean  @default(false)
  note             String?  @db.Text
  updatedAt        DateTime @updatedAt
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, word])
  @@index([userId, weaknessScore])
}

model Session {
  id               String            @id @default(cuid())
  userId           String
  mode             String            @default("sentence") // "sentence" | "weak_word" | "random" | "word_drill"
  totalKeys        Int
  missKeys         Int
  durationMs       Int
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionWords     SessionWord[]
  sessionSentences SessionSentence[]
}

model SessionWord {
  id               String  @id @default(cuid())
  sessionId        String
  word             String
  misses           Int
  activeDurationMs Int     @default(0)
  stallCount       Int     @default(0)
  stallDurationMs  Int     @default(0)
  session          Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model SessionSentence {
  id         String   @id @default(cuid())
  sessionId  String
  sentenceId String
  position   Int
  session    Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sentence   Sentence @relation(fields: [sentenceId], references: [id], onDelete: Cascade)

  @@unique([sessionId, position])
  @@index([sentenceId])
}

model BigramStat {
  id       String @id @default(cuid())
  userId   String
  bigram   String // e.g. "wa", "qw"
  attempts Int    @default(0)
  misses   Int    @default(0)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, bigram])
}

model UserSettings {
  id            String  @id @default(cuid())
  userId        String  @unique
  missLockMs    Int     @default(1000)
  penaltyResume String  @default("current")
  focusMode     Boolean @default(false)
  focusStart    Int     @default(2)
  focusEnd      Int     @default(10)
  focusRevealMs Int     @default(1000)
  user          User    @relation(fields: [userId], references: [id], onDelete: Cascade)
}
